# =============================================================================
# NYTab 环境变量示例
# =============================================================================
# 用法:
#   1. 复制本文件为 .env:  cp .env.example .env
#   2. 按实际环境修改下面的值
#   3. 设置权限:            chmod 640 .env
#
# 安全提示:
#   - .env 文件包含数据库密码与 JWT 密钥,严禁提交到 git 仓库
#   - 生产环境权限务必 0640,仅 web 运行用户可读
#   - 安装向导(/setup)执行成功后会自动写入真实 DB_* 值
#
# 键名与 backend/config/env.example.php 严格保持一致,
# 由 backend/src/Core/Env.php 解析, backend/src/Middleware/CorsMiddleware.php
# 读取 CORS_ORIGINS(逗号分隔的白名单)。
# =============================================================================

# === Database (PostgreSQL) ===
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=nytab
DB_USER=nytab
DB_PASSWORD=changeme_strong_password

# === JWT ===
# 密钥至少 32 字符随机串,生产请用 openssl rand -hex 32 生成
JWT_SECRET=change_this_to_random_64_char_string
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=604800

# === CORS ===
# 逗号分隔的来源白名单,后端 CorsMiddleware 仅放行列表内的 Origin
# 生产环境只放当前域名,开发环境可写 http://localhost:5173
CORS_ORIGINS=https://nytab.example.com

# === Upload ===
# 图标上传大小上限(字节),与 php.ini upload_max_filesize 配合
UPLOAD_MAX_SIZE=5242880

# === App ===
APP_ENV=production
APP_URL=https://nytab.example.com

# =============================================================================
# 开发环境切换提示:
#   本地开发时将以下值改回:
#     APP_ENV=development
#     APP_URL=http://localhost:5173
#     CORS_ORIGINS=http://localhost:5173
# =============================================================================
